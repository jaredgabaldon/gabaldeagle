---
import Layout from "../layouts/Layout.astro";
---

<Layout title="Projects | Jared Gabaldon">
  <section>
    <h1>Projects</h1>

    <div class="card">
      <h2>Test Event Planning Application</h2>
      <p>
        Web application supporting planning and management of test events for a
        large engineering organization.
      </p>
    </div>

    <div class="card">
      <h2>Physics Model Status Dashboard</h2>
      <p>
        Dashboard application for tracking and communicating the status of
        physics-based development models.
      </p>
    </div>

    <div class="card">
      <h2>Weather Data and Forecast Platform</h2>
      <p>
        Full-stack application for weather data, forecasts, alerts, and long-range radar visuals.
      </p>
    </div>
  </section>
</Layout>